# ── Telegram Bridge ──────────────────────
TELEGRAM_BOT_TOKEN=           # From @BotFather
TELEGRAM_FOUNDER_CHAT_ID=     # From @userinfobot

# ── Trello ───────────────────────────────
TRELLO_KEY=                   # From https://trello.com/app-key
TRELLO_TOKEN=                 # Authorize at the link on that page
TRELLO_BOARD_ID=              # From the board URL

# ── GitHub ───────────────────────────────
GITHUB_TOKEN=                 # Personal access token with repo scope

# ── AWS (for Technical Agent) ────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=me-south-1  # Bahrain region (closest to Saudi)

# ── AI Image Generation ─────────────────
GEMINI_API_KEY=               # From https://aistudio.google.com/apikey

# ── Composio (MCP integrations) ────────
COMPOSIO_API_KEY=             # From https://app.composio.dev/settings

# ── Zoho Mail (Direct OAuth) ──────────
ZOHO_CLIENT_ID=               # From https://api-console.zoho.com/
ZOHO_CLIENT_SECRET=           # From Zoho API Console Self Client
ZOHO_REFRESH_TOKEN=           # Generated via OAuth flow
ZOHO_ACCOUNT_ID=              # From Zoho Mail API /accounts endpoint
ZOHO_DOMAIN=accounts.zoho.com # accounts.zoho.com, .eu, .in, .sa

# ── Navaia Services ──────────────────────
WHATSAPP_API_TOKEN=           # WhatsApp Business API token (Baian)
SENDGRID_API_KEY=             # For email outreach
